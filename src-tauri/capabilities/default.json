{
  "$schema": "https://schema.tauri.app/capabilities/v1",
  "identifier": "default",
  "description": "Default capability for the Mesh-Talk main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "log:default",
    "dialog:default",
    "shell:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive"
  ]
}
