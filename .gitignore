# Compiled files
target/
**/*/target/

# Node.js dependencies
node_modules/
**/*/node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
*.pid
*.seed
*.pid.lock

# Coverage directory used by Jest
coverage/

# Distribution artifacts
dist/
**/*/dist/
frontend/dist/

# Build artifacts
build/
**/*/build/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

