yarn.lock
pnpm-lock.yaml

# Temporary files
tmp/
temp/

# OS generated files
Thumbs.db
.DS_Store
*.db
test_data_*

# Coverage artifacts
lcov.info
*.info
coverage/

# Playwright
frontend/playwright-report/
frontend/test-results/
