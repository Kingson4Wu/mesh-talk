{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "enabledMcpjsonServers": ["context7"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/cargo-nice-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking cargo CPU guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.rs) rustfmt --edition 2021 \"$f\" 2>/dev/null || true;; esac",
            "timeout": 15,
            "statusMessage": "Formatting Rust file"
          }
        ]
      }
    ]
  }
}
